<!-- views/partials/header.ejs -->
<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-stars me-1"></i>Synesthesia
            </a>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNav"
                aria-controls="mainNav"
                aria-expanded="false"
                aria-label="Apri il menu"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/challenges">Challenge</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/search">Cerca</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">Info</a>
                    </li>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/feed">Feed</a>
                        </li>
                        <% if (user.role === 'creator' || user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/creator/dashboard">Creator</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/upload">Carica</a>
                            </li>
                        <% } %>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link text-warning" href="/admin">Admin</a>
                            </li>
                        <% } %>
                    <% } %>
                </ul>
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <!-- Notifiche bell -->
                        <li class="nav-item dropdown me-lg-1">
                            <a class="nav-link position-relative" href="#"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false"
                               id="notifBell" title="Notifiche">
                                <i class="bi bi-bell<%= unreadNotifications > 0 ? '-fill' : '' %>"></i>
                                <% if (unreadNotifications > 0) { %>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notif-badge">
                                        <%= unreadNotifications > 9 ? '9+' : unreadNotifications %>
                                    </span>
                                <% } %>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end notif-panel" id="notifPanel">
                                <h6 class="dropdown-header d-flex justify-content-between align-items-center">
                                    Notifiche
                                    <button type="button" class="btn btn-link btn-sm text-decoration-none p-0" id="markAllRead">
                                        Segna tutte lette
                                    </button>
                                </h6>
                                <div id="notifList" class="notif-list">
                                    <p class="dropdown-item text-muted small">Caricamento...</p>
                                </div>
                            </div>
                        </li>
                        <!-- User dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-inline-flex align-items-center gap-2"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <% if (user.avatar_path) { %>
                                    <img src="<%= user.avatar_path %>" class="navbar-avatar" alt="<%= user.username %>">
                                <% } else { %>
                                    <i class="bi bi-person-circle"></i>
                                <% } %>
                                <span><%= user.username %></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="/profile/<%= user.username %>">
                                        <i class="bi bi-person me-2"></i>Il mio profilo
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/feed">
                                        <i class="bi bi-stars me-2"></i>Il mio feed
                                    </a>
                                </li>
                                <% if (user.role === 'creator' || user.role === 'admin') { %>
                                    <li>
                                        <a class="dropdown-item" href="/creator/dashboard">
                                            <i class="bi bi-speedometer2 me-2"></i>Dashboard
                                        </a>
                                    </li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form action="/auth/logout" method="POST">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-sm btn-primary" href="/register">Registrati</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <%- include('alerts') %>
    <% if (typeof user !== 'undefined' && user) { %>
        <script type="module" src="/js/notifications.js"></script>
    <% } %>
</header>
