// Descrizione narrativa per ciascuna delle 9 sfaccettature del Prisma Interiore.
// Parametri: type (1..9)
const t = Number(type);
const descriptions = {
    1: {
        name: 'Cesellatore',
        text: 'Il Cesellatore cerca la perfezione nel dettaglio. Ogni opera nasce da una scelta consapevole, ogni linea è frutto di disciplina e visione. Il suo impulso creativo è guidato dall\'ordine interiore: non si accontenta del "buono abbastanza", vuole che ogni elemento sia al suo posto. La sua sfida? Imparare che l\'imperfezione è parte della bellezza.',
    },
    2: {
        name: 'Donatore',
        text: 'Il Donatore crea per connettere. Le sue opere sono ponti tra persone, gesti che esprimono cura e desiderio di essere presente. Il suo impulso creativo nasce dal bisogno di far sentire gli altri speciali. La sua sfida? Ricordare che anche la propria voce merita di essere ascoltata.',
    },
    3: {
        name: 'Faro',
        text: 'Il Faro punta in alto. Ogni opera è un passo verso un obiettivo, una dimostrazione di ciò che è possibile raggiungere. Il suo impulso creativo è alimentato dall\'ambizione e dalla chiarezza di visione. La sua sfida? Rallentare abbastanza da sentire cosa vuole davvero, oltre il successo.',
    },
    4: {
        name: 'Lirico',
        text: 'Il Lirico trasforma le emozioni in forma. Ogni opera è un frammento del suo mondo interiore, unico e irripetibile. Il suo impulso creativo nasce dalla profondità del sentire: melanconia, bellezza, nostalgia diventano colore e suono. La sua sfida? Accettare che l\'unicità non richiede isolamento.',
    },
