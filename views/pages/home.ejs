<!-- views/pages/home.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main>
        <!-- Hero Section -->
        <section class="jumbotron text-center bg-light py-5">
            <div class="container">
                <h1 class="display-4">Benvenuto su Synesthesia</h1>
                <p class="lead">Dove la creatività incontra la connessione. Esprimi te stesso e scopri opere affini alla tua anima.</p>
                <% if (!user) { %>
                    <p>
                        <a href="/register" class="btn btn-primary my-2 me-2">Inizia ora</a>
                        <a href="/login" class="btn btn-secondary my-2">Accedi</a>
                    </p>
                <% } else { %>
                    <p>
                        <a href="/feed" class="btn btn-primary my-2">Vai al tuo Feed</a>
                        <% if (user.role === 'creator') { %>
                            <a href="/upload" class="btn btn-success my-2 ms-2">Carica la tua opera</a>
                        <% } %>
                    </p>
                <% } %>
            </div>
        </section>

        <!-- Active Challenges Section -->
        <section class="container py-5">
            <h2 class="mb-4 text-center"><i class="bi bi-trophy-fill me-2"></i>Challenge Attive</h2>
            <% if (activeChallenges && activeChallenges.length > 0) { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% activeChallenges.forEach(challenge => { %>
                        <article class="col">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title mb-2"><%= challenge.title %></h5>
                                    <p class="card-text text-muted small"><%= new Date(challenge.start_date).toLocaleDateString() %> - <%= new Date(challenge.end_date).toLocaleDateString() %></p>
                                    <p class="card-text"><%= challenge.description.substring(0, 120) %>...</p>
                                    <div class="mt-auto text-end">
                                        <a href="/challenges/<%= challenge.id %>" class="btn btn-sm btn-outline-primary">Dettagli Challenge</a>
                                    </div>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info text-center" role="alert">
                    Nessuna challenge attiva al momento. Torna presto!
                </div>
            <% } %>
            <div class="text-center mt-4">
                <a href="/challenges" class="btn btn-outline-secondary">Vedi tutte le Challenge</a>
            </div>
        </section>

        <!-- Recent Entries Section -->
        <section class="container py-5 bg-light">
            <h2 class="mb-4 text-center"><i class="bi bi-fire me-2"></i>Opere Recenti</h2>
            <% if (recentEntries && recentEntries.length > 0) { %>
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                    <% recentEntries.forEach(entry => { %>
                        <article class="col">
                            <div class="card h-100 shadow-sm">
                                <a href="/entries/<%= entry.id %>">
                                    <img src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>" class="card-img-top entry-card-img-top" alt="<%= entry.title %>">
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title"><%= entry.title %></h5>
                                    <p class="card-text text-muted small mb-2">di <a href="/profile/<%= entry.author_username %>"><%= entry.author_username %></a></p>
                                    <p class="card-text"><%= entry.description.substring(0, 80) %>...</p>
                                    <div class="mt-auto text-end">
                                        <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">Vedi opera</a>
                                    </div>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-warning text-center" role="alert">
                    Nessuna opera pubblicata di recente. Sii il primo a caricarne una!
                </div>
            <% } %>
            <div class="text-center mt-4">
                <a href="/search" class="btn btn-outline-secondary">Esplora il Catalogo Completo</a>
            </div>
        </section>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>
</html>