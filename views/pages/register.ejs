<!-- views/pages/register.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('../partials/header', { user: user }) %>

    <main class="container my-auto py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <section class="card shadow-sm p-4">
                    <header class="text-center mb-4">
                        <h1 class="h3"><i class="bi bi-person-plus-fill me-2"></i>Registrati</h1>
                        <p class="text-muted">Crea il tuo account Synesthesia</p>
                    </header>
                    
                    <%- include('../partials/alerts') %>

                    <form action="/auth/register" method="POST">
                        <div class="mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" class="form-control" id="username" name="username" value="<%= typeof username != 'undefined' ? username : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= typeof email != 'undefined' ? email : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" value="<%= typeof password != 'undefined' ? password : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="password2" class="form-label">Conferma Password</label>
                            <input type="password" class="form-control" id="password2" name="password2" value="<%= typeof password2 != 'undefined' ? password2 : '' %>" required>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Registrati</button>
                        </div>
                    </form>
                    <footer class="text-center mt-4">
                        <p class="text-muted">Hai già un account? <a href="/login">Accedi</a></p>
                    </footer>
                </section>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>
</html>