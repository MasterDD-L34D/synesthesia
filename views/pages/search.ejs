<!-- views/pages/search.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Includi Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <!-- Includi Bootstrap Icons per le icone -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Includi il tuo CSS personalizzato -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container-fluid py-4">
        <div class="row">
            <!-- Colonna Filtri di Ricerca (Sidebar) -->
            <aside class="col-lg-4 col-md-4 mb-4">
                <section class="card p-3 shadow-sm sticky-top sticky-filter-sidebar">
                    <h4 class="card-title mb-4">Filtra la Ricerca</h4>
                    <form id="searchForm" class="d-grid gap-3">
                        <!-- Ricerca Testuale -->
                        <div class="mb-3">
                            <label for="searchQuery" class="form-label visually-hidden">Cerca per titolo o descrizione</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="searchQuery" name="query" placeholder="Titolo, descrizione..." aria-label="Testo di ricerca">
                                <button class="btn btn-outline-primary" type="submit" id="searchButton">
                                    <i class="bi bi-search"></i> Cerca
                                </button>
                            </div>
                        </div>

                        <!-- Categorie Multimediali -->
                        <fieldset class="mb-3">
                            <legend class="form-label fw-bold">Categoria Multimediale</legend>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="mediaType" id="mediaTypeAll" value="" checked>
                                <label class="form-check-label" for="mediaTypeAll">Tutte</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="mediaType" id="mediaTypeImage" value="image">
                                <label class="form-check-label" for="mediaTypeImage">Immagini (Digital Art, Foto)</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="mediaType" id="mediaTypeAudio" value="audio">
                                <label class="form-check-label" for="mediaTypeAudio">Audio</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="mediaType" id="mediaTypeText" value="text">
                                <label class="form-check-label" for="mediaTypeText">Testo</label>
                            </div>
                        </fieldset>

                        <!-- Affinità Autore — Sfaccettatura del Prisma -->
                        <div class="mb-3">
                            <label for="authorEnneagramType" class="form-label fw-bold">Affinità Autore (Sfaccettatura)</label>
                            <select class="form-select" id="authorEnneagramType" name="authorEnneagramType">
                                <option value="">Tutte le sfaccettature</option>
                                <option value="1">1 &mdash; Cesellatore</option>
                                <option value="2">2 &mdash; Donatore</option>
                                <option value="3">3 &mdash; Faro</option>
                                <option value="4">4 &mdash; Lirico</option>
                                <option value="5">5 &mdash; Cartografo</option>
                                <option value="6">6 &mdash; Custode</option>
                                <option value="7">7 &mdash; Viandante</option>
                                <option value="8">8 &mdash; Titano</option>
                                <option value="9">9 &mdash; Orizzonte</option>
                            </select>
                        </div>

                        <!-- Campi per i Tag -->
                        <div class="mb-3">
                            <label for="searchTags" class="form-label fw-bold">Tag (separati da virgola)</label>
                            <input type="text" class="form-control" id="searchTags" name="tags" placeholder="es. astratto,minimal">
                        </div>
                        
                        <div class="d-grid">
                            <button type="button" id="clearFiltersBtn" class="btn btn-outline-secondary mt-2">Pulisci Filtri</button>
                        </div>
                    </form>

                    <% if (user && user.profile && user.profile.dominant_type) { %>
                        <hr class="my-4">
                        <div class="text-center">
                            <button type="button" class="btn btn-info btn-sm" id="searchByMyAffinityBtn">
                                <i class="bi bi-person-heart"></i> Opere affini al mio Prisma (<%= user.profile.dominant_type %>)
                            </button>
                            <small class="d-block text-muted mt-2">Cerca opere di autori con la stessa sfaccettatura dominante della tua.</small>
                        </div>
                    <% } %>
                </section>
            </aside>

            <!-- Colonna Risultati della Ricerca -->
            <section class="col-lg-8 col-md-8">
                <h2 class="mb-4">Risultati della Ricerca <span id="resultsCount" class="badge bg-secondary ms-2 d-none"></span></h2>
                
                <div id="searchResults" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                    <!-- Messaggio iniziale visibile finché non ci sono risultati -->
                    <div class="col-12 text-center text-muted py-5" id="initialMessage">
                        <i class="bi bi-lightbulb fs-1 d-block mb-3"></i>
                        <p class="lead">Inizia una ricerca per esplorare le opere creative di Synesthesia!</p>
                        <p>Usa i filtri sulla sinistra per raffinare la tua ricerca.</p>
                    </div>
                </div>

                <!-- Controlli di Paginazione -->
                <nav aria-label="Navigazione risultati" class="mt-5 d-none" id="paginationControls">
                    <ul class="pagination justify-content-center">
                        <li class="page-item" id="prevPageLink">
                            <a class="page-link" href="#" aria-label="Previous">
                                <span aria-hidden="true">&laquo; Precedente</span>
                            </a>
                        </li>
                        <li class="page-item disabled"><span class="page-link" id="currentPageInfo">Pagina 1 di N</span></li>
                        <li class="page-item" id="nextPageLink">
                            <a class="page-link" href="#" aria-label="Next">
                                <span aria-hidden="true">Successiva &raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>

                <!-- Messaggio per nessun risultato -->
                <div id="noResultsMessage" class="alert alert-warning text-center mt-5 d-none">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Nessun risultato trovato per i criteri di ricerca specificati. Prova a modificare i filtri.
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- Includi Bootstrap JS (bundle con Popper.js) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <!-- Includi la tua logica JS principale per Page.js -->
    <script type="module" src="/js/app.js"></script>
</body>
</html>