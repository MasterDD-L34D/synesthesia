<!-- views/pages/creator-dashboard.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <header class="mb-4">
            <h1 class="mb-1">Dashboard Creator di <%= user.username %></h1>
            <% if (creatorEnneagramType) { %>
                <p class="lead mb-0 d-flex align-items-center gap-2 flex-wrap">
                    Sfaccettatura dominante:
                    <%- include('../partials/type-badge', {
                        type: creatorEnneagramType,
                        size: 'md',
                        showLabel: true,
                        showNumber: true
                    }) %>
                </p>
            <% } else { %>
                <p class="lead mb-0 text-muted">
                    Prisma non ancora mappato.
                    <a href="/onboarding">Completa la mappatura</a>.
                </p>
            <% } %>
        </header>

        <!-- Stats aggregati -->
        <section class="row g-3 mb-4">
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-collection fs-3 text-primary"></i>
                        <h6 class="card-title mt-2 mb-1">Opere</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.total_entries %></p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-check-circle fs-3 text-success"></i>
                        <h6 class="card-title mt-2 mb-1">Pubblicate</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.published_entries %></p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-hourglass-split fs-3 text-warning"></i>
                        <h6 class="card-title mt-2 mb-1">In revisione</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.pending_entries %></p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-heart-fill fs-3 text-danger"></i>
                        <h6 class="card-title mt-2 mb-1">Like ricevuti</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.total_likes %></p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-chat-fill fs-3 text-info"></i>
                        <h6 class="card-title mt-2 mb-1">Commenti</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.total_comments %></p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-2">
                <div class="card text-center h-100">
                    <div class="card-body">
                        <i class="bi bi-eye-fill fs-3 text-secondary"></i>
                        <h6 class="card-title mt-2 mb-1">View</h6>
                        <p class="fs-4 fw-bold mb-0"><%= stats.total_views %></p>
                    </div>
                </div>
            </div>
        </section>

        <div class="row g-4 mb-5">
            <!-- Tabella opere -->
            <section class="col-lg-8">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="bi bi-bar-chart-fill me-2"></i>Le tue opere</h4>
                        <a href="/upload" class="btn btn-sm btn-light">
                            <i class="bi bi-plus-circle me-1"></i>Carica nuova
                        </a>
                    </div>
                    <div class="card-body">
                        <% if (entries && entries.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Opera</th>
                                            <th>Tipo</th>
                                            <th class="text-center">Like</th>
                                            <th class="text-center">Commenti</th>
                                            <th>Data</th>
                                            <th>Stato</th>
                                            <th>Azione</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% entries.forEach((entry) => { %>
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>" alt="<%= entry.title %>" class="rounded me-2 entry-thumbnail">
                                                        <a href="/entries/<%= entry.id %>" class="text-decoration-none fw-bold"><%= entry.title %></a>
                                                    </div>
                                                </td>
                                                <td>
                                                    <% if (entry.media_type === 'image') { %>
                                                        <i class="bi bi-image me-1"></i>Immagine
                                                    <% } else if (entry.media_type === 'audio') { %>
                                                        <i class="bi bi-music-note me-1"></i>Audio
                                                    <% } else { %>
                                                        <i class="bi bi-file-earmark-text me-1"></i>Testo
                                                    <% } %>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-danger">
                                                        <i class="bi bi-heart-fill me-1"></i><%= entry.likes_count %>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-info">
                                                        <i class="bi bi-chat-fill me-1"></i><%= entry.comments_count %>
                                                    </span>
                                                </td>
                                                <td><%= new Date(entry.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <% if (entry.status === 'published') { %>
                                                        <span class="badge bg-success">Pubblicata</span>
                                                    <% } else if (entry.status === 'pending') { %>
                                                        <span class="badge bg-warning text-dark">In revisione</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary"><%= entry.status %></span>
                                                    <% } %>
                                                </td>
                                                <td>
                                                    <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info text-center mb-0">
                                Non hai ancora caricato nessuna opera.
                                <br>
                                <a href="/upload" class="btn btn-primary mt-3">
                                    <i class="bi bi-upload me-2"></i>Inizia a caricare
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>

            <!-- Task personalizzate -->
            <section class="col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="bi bi-lightbulb-fill me-2"></i>Task Zen</h4>
                    </div>
                    <div class="card-body">
                        <% if (personalizedTasks && personalizedTasks.length > 0) { %>
                            <ul class="list-group list-group-flush list-group-prism">
                                <% personalizedTasks.forEach((task) => { %>
                                    <li class="list-group-item <%= task.completed ? 'list-group-item-success' : '' %>">
                                        <p class="mb-1 fw-bold"><%= task.content %></p>
                                        <small class="text-muted">
                                            <%= new Date(task.created_at).toLocaleDateString() %>
                                        </small>
                                        <span class="badge <%= task.completed ? 'bg-success' : 'bg-warning text-dark' %> rounded-pill float-end">
                                            <%= task.completed ? 'Completata' : 'In sospeso' %>
                                        </span>
                                    </li>
                                <% }); %>
                            </ul>
                        <% } else { %>
                            <div class="alert alert-light border text-center mb-0">
                                <p class="mb-0">Nessuna task personalizzata.</p>
                                <p class="text-muted small mt-2 mb-0">
                                    Completa il questionario di profilazione per ricevere suggerimenti.
                                </p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
