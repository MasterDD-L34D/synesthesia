<!-- views/pages/feed.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <header class="mb-4">
            <h1 class="mb-2"><i class="bi bi-stars me-2"></i>Il tuo Feed</h1>
            <% if (hasProfile) { %>
                <p class="lead mb-0 d-flex align-items-center gap-2 flex-wrap">
                    Opere e challenge selezionate in base al tuo
                    <%- include('../partials/type-badge', {
                        type: profile.dominant_type,
                        size: 'md',
                        showLabel: true,
                        showNumber: true
                    }) %>
                </p>
            <% } else { %>
                <div class="alert alert-warning mt-3" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    Completa il <a href="/onboarding" class="alert-link">questionario di profilazione</a>
                    per ricevere contenuti personalizzati.
                </div>
            <% } %>
        </header>

        <!-- Task personalizzate -->
        <% if (tasks && tasks.length > 0) { %>
            <section class="mb-5">
                <h2 class="h4 mb-3"><i class="bi bi-lightbulb me-2"></i>Task consigliate</h2>
                <div class="list-group list-group-prism">
                    <% tasks.slice(0, 5).forEach((task) => { %>
                        <article class="list-group-item d-flex justify-content-between align-items-center">
                            <span><%= task.content %></span>
                            <span class="badge bg-<%= task.completed ? 'success' : 'secondary' %> rounded-pill">
                                <%= task.completed ? 'Completata' : 'Nuova' %>
                            </span>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <!-- Challenge consigliate -->
        <section class="mb-5">
            <h2 class="h4 mb-3"><i class="bi bi-trophy me-2"></i>Challenge attive</h2>
            <% if (challenges && challenges.length > 0) { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
                    <% challenges.forEach((ch) => { %>
                        <article class="col">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title"><%= ch.title %></h5>
                                    <p class="card-text text-muted small">
                                        <%= new Date(ch.start_date).toLocaleDateString() %>
                                        &ndash;
                                        <%= new Date(ch.end_date).toLocaleDateString() %>
                                    </p>
                                    <p class="card-text"><%= ch.description.substring(0, 100) %>...</p>
                                    <a href="/challenges/<%= ch.id %>" class="btn btn-sm btn-outline-primary mt-auto">
                                        Partecipa
                                    </a>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info mb-0">Nessuna challenge attiva al momento.</div>
            <% } %>
        </section>

        <!-- Opere affini -->
        <section>
            <h2 class="h4 mb-3">
                <i class="bi bi-palette me-2"></i>Opere affini al tuo profilo
            </h2>
            <% if (entries && entries.length > 0) { %>
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    <% entries.forEach((entry) => { %>
                        <article class="col">
                            <div class="card h-100 shadow-sm">
                                <a href="/entries/<%= entry.id %>">
                                    <img
                                        src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>"
                                        class="card-img-top entry-card-img-top"
                                        alt="<%= entry.title %>"
                                    >
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0"><%= entry.title %></h5>
                                        <%- include('../partials/type-badge', {
                                            type: entry.author_dominant_type,
                                            size: 'sm',
                                            showLabel: false,
                                            showNumber: true
                                        }) %>
                                    </div>
                                    <p class="card-text small text-muted mb-2">
                                        di <a href="/profile/<%= entry.author_username %>"><%= entry.author_username %></a>
                                        &middot; <%= entry.media_type %>
                                    </p>
                                    <blockquote class="blockquote-footer fst-italic small mb-2">
                                        <%= entry.auto_caption %>
                                    </blockquote>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span>
                                            <i class="bi bi-heart-fill text-danger me-1"></i><%= entry.likes_count %>
                                            <i class="bi bi-chat-fill ms-2 me-1"></i><%= entry.comments_count %>
                                        </span>
                                        <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">Vedi</a>
                                    </div>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="alert alert-info mb-0">
                    Nessuna opera affine trovata. Esplora il
                    <a href="/search" class="alert-link">catalogo</a> o
                    <a href="/challenges" class="alert-link">le challenge</a>.
                </div>
            <% } %>
        </section>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/image-zoom.js"></script>
</body>
</html>
