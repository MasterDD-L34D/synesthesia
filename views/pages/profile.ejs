<!-- views/pages/profile.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <h1 class="mb-4">Profilo di <%= profileUser.username %></h1>
        <hr>

        <section class="row g-4 mb-5">
            <div class="col-lg-4">
                <article class="card shadow-sm p-3 text-center">
                    <div class="position-relative d-inline-block mx-auto mb-3">
                        <img
                            src="<%= profileUser.avatar_path || '/img/default-avatar.png' %>"
                            class="profile-avatar rounded-circle"
                            alt="Avatar di <%= profileUser.username %>"
                        >
                        <% if (isOwner) { %>
                            <form action="/profile/avatar" method="POST" enctype="multipart/form-data"
                                  class="avatar-upload-overlay">
                                <label for="avatarInput" class="avatar-upload-label" title="Cambia avatar">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" id="avatarInput" name="avatar"
                                       accept="image/jpeg,image/png,image/gif,image/webp"
                                       class="d-none"
                                       onchange="this.form.submit()">
                            </form>
                        <% } %>
                    </div>
                    <h2 class="h4 mb-2"><%= profileUser.username %></h2>
                    <p class="text-muted small"><%= profileUser.description || 'Nessuna descrizione.' %></p>

                    <% if (profileUser.dominant_type) { %>
                        <div class="mb-3 d-flex justify-content-center">
                            <%- include('../partials/prism-wheel', {
                                activeType: profileUser.dominant_type,
                                size: 140
                            }) %>
                        </div>
                        <div class="mb-2 d-flex justify-content-center">
                            <%- include('../partials/type-badge', {
                                type: profileUser.dominant_type,
                                size: 'lg',
                                showLabel: true,
                                showNumber: true,
                                variant: 'filled'
                            }) %>
                        </div>
                        <%- include('../partials/type-description', { type: profileUser.dominant_type }) %>
                        <% if (profileUser.wing) { %>
                            <p class="mb-1 text-muted small">Riflesso: w<%= profileUser.wing %></p>
                        <% } %>
                    <% } else { %>
                        <p class="mb-1 text-muted small">Prisma non ancora mappato.</p>
                    <% } %>

                    <% if (profileUser.role === 'creator' || profileUser.role === 'admin') { %>
                        <span class="badge bg-info mt-2">
                            <i class="bi bi-pencil-square me-1"></i>Creator
                        </span>
                    <% } %>
                    <% if (profileUser.role === 'admin') { %>
                        <span class="badge bg-warning text-dark mt-2 ms-1">
                            <i class="bi bi-shield-fill me-1"></i>Admin
                        </span>
                    <% } %>

                    <% if (isOwner && !profileUser.onboarding_completed) { %>
                        <div class="mt-3">
                            <a href="/onboarding" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-stars me-2"></i>Completa questionario
                            </a>
                        </div>
                    <% } %>
                </article>
            </div>

            <div class="col-lg-8">
                <section class="card shadow-sm p-4">
                    <h2 class="h4 mb-3">Opere pubblicate</h2>
                    <% if (profileEntries && profileEntries.length > 0) { %>
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                            <% profileEntries.forEach((entry) => { %>
                                <article class="col">
                                    <div class="card h-100">
                                        <img
                                            src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>"
                                            class="card-img-top entry-card-img-top"
                                            alt="<%= entry.title %>"
                                        >
                                        <div class="card-body">
                                            <h5 class="card-title"><%= entry.title %></h5>
                                            <p class="card-text small text-muted mb-2">
                                                <i class="bi bi-tag me-1"></i><%= entry.media_type %>
                                                <span class="ms-2">
                                                    <i class="bi bi-heart-fill text-danger me-1"></i><%= entry.likes_count %>
                                                </span>
                                                <span class="ms-2">
                                                    <i class="bi bi-chat-fill me-1"></i><%= entry.comments_count %>
                                                </span>
                                            </p>
                                            <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">
                                                Vedi
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="alert alert-info text-center mb-0" role="alert">
                            Nessuna opera pubblicata da <%= profileUser.username %>.
                        </div>
                    <% } %>
                </section>
            </div>
        </section>

        <% if (isOwner && savedEntries && savedEntries.length > 0) { %>
            <section class="card shadow-sm p-4 mt-4">
                <h2 class="h4 mb-3"><i class="bi bi-bookmark-fill me-2"></i>Opere salvate</h2>
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
                    <% savedEntries.forEach((entry) => { %>
                        <article class="col">
                            <div class="card h-100">
                                <a href="/entries/<%= entry.id %>">
                                    <img
                                        src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>"
                                        class="card-img-top entry-card-img-top"
                                        alt="<%= entry.title %>"
                                    >
                                </a>
                                <div class="card-body">
                                    <h5 class="card-title"><%= entry.title %></h5>
                                    <p class="card-text small text-muted mb-1">
                                        di <a href="/profile/<%= entry.author_username %>"><%= entry.author_username %></a>
                                        <span class="ms-2"><i class="bi bi-heart-fill text-danger me-1"></i><%= entry.likes_count %></span>
                                    </p>
                                    <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">Vedi</a>
                                </div>
                            </div>
                        </article>
                    <% }); %>
                </div>
            </section>
        <% } %>

        <% if (isOwner) { %>
            <section class="card shadow-sm p-4 mt-4">
                <h2 class="h4 mb-3">Le tue Risonanze del Prisma</h2>
                <% const maxScore = Math.max(1, profileUser.score_type_1, profileUser.score_type_2,
                    profileUser.score_type_3, profileUser.score_type_4, profileUser.score_type_5,
                    profileUser.score_type_6, profileUser.score_type_7, profileUser.score_type_8,
                    profileUser.score_type_9); %>
                <div class="row row-cols-1 row-cols-md-3 g-3">
                    <% for (let i = 1; i <= 9; i++) { %>
                        <% const score = profileUser[`score_type_${i}`] || 0; %>
                        <% const pct = Math.round((score / maxScore) * 100); %>
                        <div class="col">
                            <div class="card bg-light border-primary h-100">
                                <div class="card-body">
                                    <h6 class="card-title mb-2 d-flex align-items-center gap-2">
                                        <%- include('../partials/type-badge', {
                                            type: i,
                                            size: 'sm',
                                            showLabel: true,
                                            showNumber: true
                                        }) %>
                                        <% if (i === profileUser.dominant_type) { %>
                                            <i class="bi bi-star-fill text-warning ms-auto"></i>
                                        <% } %>
                                    </h6>
                                    <div class="progress score-bar">
                                        <div
                                            class="progress-bar bg-info"
                                            role="progressbar"
                                            data-width="<%= pct %>"
                                            aria-valuenow="<%= score %>"
                                            aria-valuemin="0"
                                            aria-valuemax="<%= maxScore %>"
                                        >
                                            <%= score %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </section>
        <% } %>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/profile.js"></script>
</body>
</html>
