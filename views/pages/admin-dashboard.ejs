<!-- views/pages/admin-dashboard.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <h1 class="mb-4">Dashboard Amministratore</h1>
        <p class="lead">Benvenuto, <%= user.username %>. Gestisci i contenuti e le challenge della piattaforma.</p>
        <hr>

        <!-- Sezione Messaggi Flash -->
        <%- include('../partials/alerts') %>

        <div class="row g-4 mb-5">
            <!-- Sezione Opere in Moderazione -->
            <section class="col-lg-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-warning text-dark">
                        <h4 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>Opere in Attesa di Moderazione (<%= pendingEntries.length %>)</h4>
                    </div>
                    <div class="card-body">
                        <% if (pendingEntries && pendingEntries.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th scope="col">Opera</th>
                                            <th scope="col">Autore</th>
                                            <th scope="col">Tipo</th>
                                            <th scope="col">Data</th>
                                            <th scope="col">Azioni</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% pendingEntries.forEach(entry => { %>
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>" alt="<%= entry.title %>" class="rounded me-2 entry-thumbnail">
                                                        <a href="/entries/<%= entry.id %>" class="text-decoration-none fw-bold"><%= entry.title %></a>
                                                    </div>
                                                </td>
                                                <td><a href="/profile/<%= entry.author_username %>"><%= entry.author_username %></a></td>
                                                <td>
                                                    <% if (entry.media_type === 'image') { %>
                                                        <i class="bi bi-image" title="Immagine"></i>
                                                    <% } else if (entry.media_type === 'audio') { %>
                                                        <i class="bi bi-music-note" title="Audio"></i>
                                                    <% } else if (entry.media_type === 'text') { %>
                                                        <i class="bi bi-file-earmark-text" title="Testo"></i>
                                                    <% } %>
                                                    <%= entry.media_type %>
                                                </td>
                                                <td><%= new Date(entry.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <form action="/admin/entries/<%= entry.id %>/moderate" method="POST" class="d-inline">
                                                        <button type="submit" name="status" value="published" class="btn btn-sm btn-success me-1" title="Approva"><i class="bi bi-check-lg"></i></button>
                                                        <button type="submit" name="status" value="rejected" class="btn btn-sm btn-danger" title="Rifiuta"><i class="bi bi-x-lg"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-success text-center mb-0" role="alert">
                                <i class="bi bi-check-circle me-2"></i>Nessuna opera in attesa di moderazione. Tutto pulito!
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>

            <!-- Sezione Gestione Challenge -->
            <section class="col-lg-12 mt-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h4 class="mb-0"><i class="bi bi-trophy-fill me-2"></i>Gestione Challenge</h4>
                    </div>
                    <div class="card-body">
                        <!-- Form per Nuova Challenge -->
                        <h5 class="mb-3">Crea Nuova Challenge</h5>
                        <form action="/admin/challenges" method="POST" class="mb-5 p-3 border rounded shadow-sm">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="challengeTitle" class="form-label">Titolo Challenge</label>
                                    <input type="text" class="form-control" id="challengeTitle" name="title" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="challengeDescription" class="form-label">Descrizione</label>
                                    <textarea class="form-control" id="challengeDescription" name="description" rows="2" required></textarea>
                                </div>
                                <div class="col-md-3">
                                    <label for="startDate" class="form-label">Data Inizio</label>
                                    <input type="date" class="form-control" id="startDate" name="startDate" value="<%= currentDate %>" required>
                                </div>
                                <div class="col-md-3">
                                    <label for="endDate" class="form-label">Data Fine</label>
                                    <input type="date" class="form-control" id="endDate" name="endDate" required>
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="isActive" name="isActive">
                                        <label class="form-check-label" for="isActive">Attiva Subito</label>
                                    </div>
                                </div>
                                <div class="col-md-3 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-circle me-2"></i>Crea Challenge</button>
                                </div>
                            </div>
                        </form>

                        <!-- Lista Challenge Esistenti -->
                        <h5 class="mb-3">Challenge Esistenti</h5>
                        <% if (allChallenges && allChallenges.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th scope="col">ID</th>
                                            <th scope="col">Titolo</th>
                                            <th scope="col">Periodo</th>
                                            <th scope="col">Stato</th>
                                            <th scope="col">Azioni</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allChallenges.forEach(challenge => { %>
                                            <tr>
                                                <td><%= challenge.id %></td>
                                                <td><a href="/challenges/<%= challenge.id %>" class="text-decoration-none"><%= challenge.title %></a></td>
                                                <td><%= new Date(challenge.start_date).toLocaleDateString() %> - <%= new Date(challenge.end_date).toLocaleDateString() %></td>
                                                <td>
                                                    <span class="badge <%= challenge.is_active ? 'bg-success' : 'bg-secondary' %>">
                                                        <%= challenge.is_active ? 'Attiva' : 'Inattiva' %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <!-- Bottone per Modifica (apri modale) -->
                                                    <button type="button" class="btn btn-sm btn-outline-secondary me-1"
                                                        data-bs-toggle="modal" data-bs-target="#editChallengeModal"
                                                        data-id="<%= challenge.id %>"
                                                        data-title="<%= challenge.title %>"
                                                        data-description="<%= challenge.description %>"
                                                        data-startdate="<%= new Date(challenge.start_date).toISOString().slice(0,10) %>"
                                                        data-enddate="<%= new Date(challenge.end_date).toISOString().slice(0,10) %>"
                                                        data-isactive="<%= challenge.is_active %>"
                                                        title="Modifica Challenge">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    
                                                    <!-- Form per Attiva/Disattiva -->
                                                    <form action="/admin/challenges/<%= challenge.id %>/toggle-status" method="POST" class="d-inline">
                                                        <% if (challenge.is_active) { %>
                                                            <button type="submit" name="isActive" value="false" class="btn btn-sm btn-outline-danger" title="Disattiva"><i class="bi bi-toggle-on"></i></button>
                                                        <% } else { %>
                                                            <button type="submit" name="isActive" value="true" class="btn btn-sm btn-outline-success" title="Attiva"><i class="bi bi-toggle-off"></i></button>
                                                        <% } %>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info text-center mb-0" role="alert">
                                Nessuna challenge creata. Usa il form qui sopra per crearne una!
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>

             <!-- Sezione Gestione Utenti (Aggiunta per demo, con dati fittizi) -->
             <section class="col-lg-12 mt-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="bi bi-people-fill me-2"></i>Gestione Utenti</h4>
                    </div>
                    <div class="card-body">
                        <% if (allUsers && allUsers.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th scope="col">ID</th>
                                            <th scope="col">Username</th>
                                            <th scope="col">Email</th>
                                            <th scope="col">Ruolo</th>
                                            <th scope="col">Creator Sbloccato</th>
                                            <th scope="col">Registrato Il</th>
                                            <th scope="col">Azioni</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% allUsers.forEach(user => { %>
                                            <tr>
                                                <td><%= user.id %></td>
                                                <td><a href="/profile/<%= user.username %>"><%= user.username %></a></td>
                                                <td><%= user.email %></td>
                                                <td><span class="badge bg-secondary"><%= user.role %></span></td>
                                                <td>
                                                    <% if (user.is_creator_unlocked) { %>
                                                        <i class="bi bi-check-circle-fill text-success" title="Sì"></i>
                                                    <% } else { %>
                                                        <i class="bi bi-x-circle-fill text-danger" title="No"></i>
                                                    <% } %>
                                                </td>
                                                <td><%= new Date(user.created_at).toLocaleDateString() %></td>
                                                <td>
                                                    <button type="button" class="btn btn-sm btn-outline-primary" title="Modifica Ruolo"><i class="bi bi-person-gear"></i></button>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Elimina Utente"><i class="bi bi-person-x"></i></button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info text-center mb-0" role="alert">
                                Nessun utente registrato.
                            </div>
                        <% } %>
                    </div>
                </div>
            </section>
        </div>

        <!-- Modale per Modifica Challenge (mantenuto nel template per semplicità d'esame, ma JS potrebbe essere separato) -->
        <div class="modal fade" id="editChallengeModal" tabindex="-1" aria-labelledby="editChallengeModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form id="editChallengeForm" method="POST">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title" id="editChallengeModalLabel">Modifica Challenge</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <!-- Campo nascosto per simulare PATCH (se Express non supporta direttamente i verbi PATCH per form) -->
                            <input type="hidden" name="_method" value="PATCH">
                            
                            <div class="mb-3">
                                <label for="editChallengeTitle" class="form-label">Titolo Challenge</label>
                                <input type="text" class="form-control" id="editChallengeTitle" name="title" required>
                            </div>
                            <div class="mb-3">
                                <label for="editChallengeDescription" class="form-label">Descrizione</label>
                                <textarea class="form-control" id="editChallengeDescription" name="description" rows="3" required></textarea>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="editStartDate" class="form-label">Data Inizio</label>
                                    <input type="date" class="form-control" id="editStartDate" name="startDate" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="editEndDate" class="form-label">Data Fine</label>
                                    <input type="date" class="form-control" id="editEndDate" name="endDate" required>
                                </div>
                            </div>
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" type="checkbox" id="editIsActive" name="isActive">
                                <label class="form-check-label" for="editIsActive">Challenge Attiva</label>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                            <button type="submit" class="btn btn-primary">Salva Modifiche</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </main>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/admin-dashboard.js"></script>
</body>
</html>