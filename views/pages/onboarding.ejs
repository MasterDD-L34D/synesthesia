<!-- views/pages/onboarding.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <h1 class="mb-3">Mappatura del Prisma Interiore</h1>
        <p class="lead">
            Rispondi a <%= questions.length %> domande per scoprire la tua
            <strong>sfaccettatura dominante</strong> e ricevere contenuti coerenti con la tua risonanza.
        </p>

        <% if (alreadyCompleted) { %>
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Hai già mappato il tuo Prisma. Rifarlo sommerà le nuove risonanze a quelle esistenti.
            </div>
        <% } %>

        <section class="card shadow-sm p-4">
            <form action="/onboarding" method="POST">
                <% questions.forEach((q, idx) => { %>
                    <fieldset class="mb-4 pb-3 border-bottom">
                        <legend class="h5">
                            <span class="badge bg-secondary me-2"><%= idx + 1 %></span>
                            <%= q.text %>
                        </legend>
                        <% q.options.forEach((opt, optIdx) => { %>
                            <div class="form-check">
                                <input
                                    class="form-check-input"
                                    type="radio"
                                    name="q_<%= q.id %>"
                                    id="q<%= q.id %>_opt<%= optIdx %>"
                                    value="<%= opt.value %>"
                                    <%= optIdx === 0 ? 'required' : '' %>
                                >
                                <label class="form-check-label" for="q<%= q.id %>_opt<%= optIdx %>">
                                    <%= opt.text %>
                                </label>
                            </div>
                        <% }); %>
                    </fieldset>
                <% }); %>

                <div class="d-flex justify-content-between align-items-center">
                    <a href="/" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Annulla
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle-fill me-2"></i>Mappa il mio Prisma
                    </button>
                </div>
            </form>
            <footer class="mt-4 text-center text-muted">
                <p class="small mb-0">
                    Le tue risposte vengono tradotte in 9 risonanze sulle sfaccettature del Prisma.
                </p>
            </footer>
        </section>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>
</html>
