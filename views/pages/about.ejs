<!-- views/pages/about.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-5">
        <header class="text-center mb-5">
            <div class="syn-mark-lg mx-auto mb-3" style="width:80px;height:80px;background:url('/img/prism-mark.svg') no-repeat center/contain"></div>
            <h1>Cos'è Synesthesia</h1>
            <p class="lead">Sfide artistiche multimediali guidate dal tuo Prisma Interiore.</p>
        </header>

        <!-- Concept -->
        <section class="card shadow-sm p-4 mb-5">
            <h2 class="h4 mb-3"><i class="bi bi-stars me-2"></i>Il Prisma Interiore</h2>
            <p>
                Synesthesia analizza le tue scelte e interazioni per costruire un profilo unico basato su
                <strong>9 sfaccettature</strong> della personalità creativa. Non è un test statico: il tuo Prisma
                evolve man mano che partecipi alla piattaforma.
            </p>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3 mt-3">
                <%
                const facets = [
                    { n: 1, name: 'Cesellatore', icon: 'bi-square-fill', essence: 'Ordine e precisione' },
                    { n: 2, name: 'Donatore', icon: 'bi-heart-fill', essence: 'Cura ed empatia' },
                    { n: 3, name: 'Faro', icon: 'bi-trophy-fill', essence: 'Slancio e visione' },
                    { n: 4, name: 'Lirico', icon: 'bi-droplet-fill', essence: 'Voce unica e introspezione' },
                    { n: 5, name: 'Cartografo', icon: 'bi-eye-fill', essence: 'Osservazione e profondità' },
                    { n: 6, name: 'Custode', icon: 'bi-shield-fill', essence: 'Lealtà e sicurezza' },
                    { n: 7, name: 'Viandante', icon: 'bi-lightning-charge-fill', essence: 'Meraviglia ed energia' },
                    { n: 8, name: 'Titano', icon: 'bi-gem', essence: 'Forza e determinazione' },
                    { n: 9, name: 'Orizzonte', icon: 'bi-yin-yang', essence: 'Quiete e armonia' },
                ];
                %>
                <% facets.forEach((f) => { %>
                    <div class="col">
                        <div class="d-flex align-items-center gap-3 p-3 rounded type-bg-<%= f.n %>" style="color:#fff">
                            <i class="bi <%= f.icon %> fs-4"></i>
                            <div>
                                <strong><%= f.n %>. <%= f.name %></strong>
                                <br><small><%= f.essence %></small>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>

        <!-- Ruoli -->
        <section class="mb-5">
            <h2 class="h4 mb-4"><i class="bi bi-people-fill me-2"></i>I ruoli della piattaforma</h2>
            <div class="row g-4">
                <!-- Guest -->
                <div class="col-md-6 col-lg-3">
                    <article class="card h-100 text-center">
                        <div class="card-body">
                            <i class="bi bi-eye fs-1 text-muted"></i>
                            <h3 class="h5 mt-3">Guest</h3>
                            <p class="small text-muted">Visitatore non registrato</p>
                            <ul class="list-unstyled small text-start">
                                <li><i class="bi bi-check-circle text-success me-1"></i>Navigare home e challenge</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Vedere dettaglio opere</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Ricerca server-side</li>
                                <li><i class="bi bi-x-circle text-danger me-1"></i>Like, commenti, salvataggi</li>
                                <li><i class="bi bi-x-circle text-danger me-1"></i>Upload opere</li>
                            </ul>
                        </div>
                    </article>
                </div>
                <!-- Registered -->
                <div class="col-md-6 col-lg-3">
                    <article class="card h-100 text-center">
                        <div class="card-body">
                            <i class="bi bi-person-fill fs-1" style="color:var(--syn-iris)"></i>
                            <h3 class="h5 mt-3">Registered</h3>
                            <p class="small text-muted">Utente registrato</p>
                            <ul class="list-unstyled small text-start">
                                <li><i class="bi bi-check-circle text-success me-1"></i>Tutto del Guest</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Mappatura del Prisma</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Like, commenti, salvataggi</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Feed personalizzato</li>
                                <li><i class="bi bi-x-circle text-danger me-1"></i>Upload opere</li>
                            </ul>
                            <p class="small fst-italic mt-2 mb-0">Registrazione gratuita</p>
                        </div>
                    </article>
                </div>
                <!-- Creator -->
                <div class="col-md-6 col-lg-3">
                    <article class="card h-100 text-center border-primary">
                        <div class="card-body">
                            <i class="bi bi-brush-fill fs-1" style="color:var(--syn-ember)"></i>
                            <h3 class="h5 mt-3">Creator</h3>
                            <p class="small text-muted">Artista attivo</p>
                            <ul class="list-unstyled small text-start">
                                <li><i class="bi bi-check-circle text-success me-1"></i>Tutto del Registered</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Upload opere (img/audio/testo)</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Partecipare alle challenge</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Dashboard con statistiche</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Task Zen personalizzate</li>
                            </ul>
                            <div class="alert alert-info small py-2 px-3 mt-2 mb-0">
                                <i class="bi bi-unlock me-1"></i>
                                <strong>Come sbloccare:</strong> interagisci con almeno 10 opere
                                (like + commenti + salvataggi). La promozione è automatica!
                            </div>
                        </div>
                    </article>
                </div>
                <!-- Admin -->
                <div class="col-md-6 col-lg-3">
                    <article class="card h-100 text-center">
                        <div class="card-body">
                            <i class="bi bi-shield-lock-fill fs-1 text-warning"></i>
                            <h3 class="h5 mt-3">Admin</h3>
                            <p class="small text-muted">Moderatore</p>
                            <ul class="list-unstyled small text-start">
                                <li><i class="bi bi-check-circle text-success me-1"></i>Tutto del Creator</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Moderare opere pending</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Creare/modificare challenge</li>
                                <li><i class="bi bi-check-circle text-success me-1"></i>Gestire utenti</li>
                            </ul>
                            <p class="small fst-italic mt-2 mb-0">Ruolo assegnato manualmente</p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <!-- Come funziona -->
        <section class="card shadow-sm p-4 mb-5">
            <h2 class="h4 mb-3"><i class="bi bi-arrow-right-circle me-2"></i>Come funziona</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="text-center mb-2">
                        <span class="badge bg-primary rounded-circle p-3 fs-5">1</span>
                    </div>
                    <h5 class="text-center">Registrati</h5>
                    <p class="small text-center text-muted">Crea il tuo account e completa la Mappatura del Prisma rispondendo a 30 domande sulla tua personalità creativa.</p>
                </div>
                <div class="col-md-4">
                    <div class="text-center mb-2">
                        <span class="badge bg-primary rounded-circle p-3 fs-5">2</span>
                    </div>
                    <h5 class="text-center">Interagisci</h5>
                    <p class="small text-center text-muted">Esplora opere, metti like, commenta e salva. Ogni interazione raffina il tuo profilo e ti avvicina allo sblocco Creator.</p>
                </div>
                <div class="col-md-4">
                    <div class="text-center mb-2">
                        <span class="badge bg-primary rounded-circle p-3 fs-5">3</span>
                    </div>
                    <h5 class="text-center">Crea</h5>
                    <p class="small text-center text-muted">Da Creator, carica le tue opere, partecipa alle challenge, ricevi task personalizzate e vedi le tue statistiche.</p>
                </div>
            </div>
        </section>

        <div class="text-center">
            <% if (!user) { %>
                <a href="/register" class="btn btn-primary btn-lg me-2">Registrati ora</a>
                <a href="/login" class="btn btn-outline-secondary btn-lg">Accedi</a>
            <% } else { %>
                <a href="/feed" class="btn btn-primary btn-lg">Vai al tuo Feed</a>
            <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
