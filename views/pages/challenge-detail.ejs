<!-- views/pages/challenge-detail.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <% if (challenge) { %>
            <article class="card shadow-sm mb-4">
                <header class="card-header bg-primary text-white">
                    <h1 class="h3 mb-0"><%= challenge.title %></h1>
                </header>
                <div class="card-body">
                    <p class="card-text lead"><%= challenge.description %></p>
                    <ul class="list-group list-group-flush mb-3">
                        <li class="list-group-item"><i class="bi bi-calendar-check me-2"></i><strong>Inizio:</strong> <%= new Date(challenge.start_date).toLocaleDateString() %></li>
                        <li class="list-group-item"><i class="bi bi-calendar-x me-2"></i><strong>Fine:</strong> <%= new Date(challenge.end_date).toLocaleDateString() %></li>
                        <li class="list-group-item"><i class="bi bi-lightbulb me-2"></i><strong>Stato:</strong>
                            <span class="badge <%= challenge.is_active ? 'bg-success' : 'bg-secondary' %>">
                                <%= challenge.is_active ? 'Attiva' : 'Inattiva' %>
                            </span>
                        </li>
                        <% if (challenge.prompt_content) { %>
                            <li class="list-group-item"><i class="bi bi-quote me-2"></i><strong>Prompt:</strong> "<%= challenge.prompt_content %>"</li>
                        <% } %>
                    </ul>
                    <p class="card-text text-muted small">Creato il <%= new Date(challenge.created_at).toLocaleDateString() %></p>
                </div>
                <footer class="card-footer text-center">
                    <% if (user && user.role === 'creator' && challenge.is_active) { %>
                        <a href="/upload?challengeId=<%= challenge.id %>" class="btn btn-success"><i class="bi bi-upload me-2"></i>Partecipa con la tua opera!</a>
                    <% } else if (user && user.role === 'creator' && !challenge.is_active) { %>
                        <p class="text-warning mb-0"><i class="bi bi-exclamation-circle me-2"></i>Questa challenge è inattiva.</p>
                    <% } else { %>
                        <p class="text-muted mb-0">Registrati o accedi come Creator per partecipare a questa challenge.</p>
                    <% } %>
                </footer>
            </article>

            <section class="mt-5">
                <h2 class="mb-4">Opere Partecipanti (<%= entries.length %>)</h2>
                <% if (entries && entries.length > 0) { %>
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                        <% entries.forEach(entry => { %>
                            <article class="col">
                                <div class="card h-100 shadow-sm">
                                    <img src="<%= entry.thumbnail_path || '/img/default-thumbnail.png' %>" class="card-img-top entry-card-img-top" alt="<%= entry.title %>">
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title"><%= entry.title %></h5>
                                        <p class="card-text text-muted small mb-2">di <a href="/profile/<%= entry.author_username %>"><%= entry.author_username %></a></p>
                                        <p class="card-text"><%= entry.description.substring(0, 100) %>...</p>
                                        <div class="mt-auto d-flex justify-content-end">
                                            <a href="/entries/<%= entry.id %>" class="btn btn-sm btn-outline-primary">Vedi opera</a>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="alert alert-info text-center" role="alert">
                        Nessuna opera ha ancora partecipato a questa challenge. Sii il primo!
                    </div>
                <% } %>
            </section>

        <% } else { %>
            <div class="alert alert-danger text-center" role="alert">
                Challenge non trovata.
            </div>
        <% } %>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>
</html>