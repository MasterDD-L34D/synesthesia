<!-- views/pages/upload-entry.ejs -->
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header', { user: user }) %>

    <main class="container py-4">
        <h1 class="mb-4">Carica la Tua Nuova Opera</h1>
        <p class="lead">Condividi la tua creatività con la community di Synesthesia.</p>
        <hr>

        <section class="card shadow-sm p-4">
            <h2 class="h4 mb-3">Dettagli dell'Opera</h2>
            <form action="/api/entries" method="POST" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="entryTitle" class="form-label">Titolo dell'Opera</label>
                    <input type="text" class="form-control" id="entryTitle" name="title" required>
                </div>
                <div class="mb-3">
                    <label for="entryDescription" class="form-label">Descrizione</label>
                    <textarea class="form-control" id="entryDescription" name="description" rows="4" required></textarea>
                </div>
                <div class="mb-3">
                    <label for="mediaFile" class="form-label">Carica File (Immagine, Audio, Testo)</label>
                    <input class="form-control" type="file" id="mediaFile" name="mediaFile" accept="image/*,audio/*,text/plain" required>
                    <div class="form-text">Dimensione massima: 10MB. Formati supportati: JPG, PNG, GIF, MP3, WAV, TXT.</div>
                </div>
                <div class="mb-3">
                    <label for="challengeId" class="form-label">Partecipa a una Challenge (Opzionale)</label>
                    <select class="form-select" id="challengeId" name="challengeId">
                        <option value="">Nessuna Challenge</option>
                        <% activeChallenges.forEach((ch) => { %>
                            <option value="<%= ch.id %>"><%= ch.title %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success"><i class="bi bi-upload me-2"></i>Carica Opera</button>
                </div>
            </form>
            <footer class="mt-4 text-center text-muted">
                <p>La tua opera sarà sottoposta a revisione prima della pubblicazione.</p>
            </footer>
        </section>
    </main>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/js/app.js"></script>
</body>
</html>